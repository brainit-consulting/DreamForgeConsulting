generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================================
// Auth tables (better-auth compatible)
// =============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified Boolean   @default(false)
  name          String
  image         String?
  role          UserRole  @default(CLIENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions Session[]
  accounts Account[]
  client   Client?
  activities Activity[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

enum UserRole {
  ADMIN
  CLIENT
}

// =============================================
// CRM Models
// =============================================

model Lead {
  id        String     @id @default(cuid())
  name      String
  email     String
  company   String?
  phone     String?
  website   String?
  address   String?    @db.Text
  status    LeadStatus @default(NEW)
  source    String?
  notes     String?    @db.Text
  value     Float?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("leads")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  CONVERTED
  LOST
}

model Client {
  id        String   @id @default(cuid())
  userId    String   @unique
  company   String
  email     String
  phone     String?
  website   String?
  address   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects Project[]
  invoices Invoice[]
  tickets  Ticket[]

  @@map("clients")
}

model Project {
  id          String        @id @default(cuid())
  clientId    String
  name        String
  description String?       @db.Text
  status      ProjectStatus @default(DISCOVERY)
  startDate   DateTime?
  deadline    DateTime?
  budget      Float?
  progress    Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  client     Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invoices   Invoice[]
  tickets    Ticket[]
  stageTasks StageTask[]
  stageNotes StageNote[]

  @@map("projects")
}

model StageTask {
  id        String        @id @default(cuid())
  projectId String
  stage     ProjectStatus
  title     String
  completed Boolean       @default(false)
  sortOrder Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, stage])
  @@map("stage_tasks")
}

model StageNote {
  id        String        @id @default(cuid())
  projectId String
  stage     ProjectStatus
  content   String        @db.Text
  createdAt DateTime      @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, stage])
  @@map("stage_notes")
}

enum ProjectStatus {
  DISCOVERY
  DESIGN
  DEVELOPMENT
  TESTING
  DEPLOYMENT
  LAUNCHED
  SUPPORT
}

model Invoice {
  id              String        @id @default(cuid())
  projectId       String?
  clientId        String
  stripeInvoiceId String?
  amount          Float
  status          InvoiceStatus @default(DRAFT)
  description     String?       @db.Text
  dueDate         DateTime?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  client  Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

model Ticket {
  id          String         @id @default(cuid())
  clientId    String
  projectId   String?
  subject     String
  description String         @db.Text
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  client  Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@map("tickets")
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Activity {
  id          String   @id @default(cuid())
  type        String
  description String
  entityType  String
  entityId    String
  userId      String?
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@map("activities")
}
